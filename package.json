{
  "name": "chordprojs",
  "version": "1.0.0",
  "description": "ChordPro file parser and renderer for JavaScript",
  "type": "module",
  "main": "dist/chordprojs.min.js",
  "module": "dist/chordprojs.esm.js",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "start": "npm run serve",
    "serve": "npx serve -l 3000 .",
    "preview": "npm run build && npm run serve",
    "lint": "eslint src",
    "test": "jest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "chordpro",
    "music",
    "chord",
    "lyrics",
    "parser"
  ],
  "author": "Eric Berg <eberg@bergbrains.com>",
  "license": "MIT",
  "devDependencies": {
    "globals": "^16.0.0",
    "@babel/preset-env": "7.29.0",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "babel-jest": "30.3.0",
    "baseline-browser-mapping": "2.10.8",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "rollup": "4.59.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-postcss": "4.0.2",
    "rollup-plugin-serve": "^3.0.0",
    "typescript": "5.9.3"
  },
  "dependencies": {}
}
